{
  "compilerOptions": {
    "moduleResolution": "node",
    "module": "esnext",
    "target": "es2022",
    "types": [
      "node",
      "@wdio/globals/types",
      "expect-webdriverio",
      "@wdio/mocha-framework",
      "@wdio/browser-runner"
    ],
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "allowJs": true,
  },
  "include": [
    "src",
    "vite.config.ts",
    "wdio.conf.ts",
    "eslint.config.mjs"
  ]
}